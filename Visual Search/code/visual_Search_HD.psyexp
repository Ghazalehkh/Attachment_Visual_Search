        <Param val="import * as random from 'random';&amp;#10;fixation_duration = Math.random.uniform(0.5, 1.0);&amp;#10;psychoJS.experiment.addData(&quot;fixation_duration&quot;, fixation_duration);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
