        <Param val="click_result = &quot;&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="click_result = &quot;&quot;  " valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="clicked_image = None&amp;#10;&amp;#10;&amp;#10;if mouse_resp_3.getPressed()[0]:  &amp;#10;    &amp;#10;    if mouse_resp_3.isPressedIn(num1):&amp;#10;        clicked_image = cue1  &amp;#10;    elif mouse_resp_3.isPressedIn(num2):&amp;#10;        clicked_image = cue2&amp;#10;    elif mouse_resp_3.isPressedIn(num3):&amp;#10;        clicked_image = cue3&amp;#10;    elif mouse_resp_3.isPressedIn(num4):&amp;#10;        clicked_image = cue4&amp;#10;    elif mouse_resp_3.isPressedIn(num5):&amp;#10;        clicked_image = cue5&amp;#10;    elif mouse_resp_3.isPressedIn(num6):&amp;#10;        clicked_image = cue6&amp;#10;    elif mouse_resp_3.isPressedIn(num7):&amp;#10;        clicked_image = cue7&amp;#10;    elif mouse_resp_3.isPressedIn(num8):&amp;#10;        clicked_image = cue8&amp;#10;    elif mouse_resp_3.isPressedIn(num9):&amp;#10;        clicked_image = cue9&amp;#10;&amp;#10;    &amp;#10;    if clicked_image is not None:&amp;#10;        &amp;#10;        click_result = (clicked_image == str(cor_resp))  &amp;#10;        &amp;#10;        &amp;#10;        continueRoutine = False" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="clicked_image = null;&amp;#10;if (mouse_resp_3.getPressed()[0]) {&amp;#10;    if (mouse_resp_3.isPressedIn(num1)) {&amp;#10;        clicked_image = cue1;&amp;#10;    } else {&amp;#10;        if (mouse_resp_3.isPressedIn(num2)) {&amp;#10;            clicked_image = cue2;&amp;#10;        } else {&amp;#10;            if (mouse_resp_3.isPressedIn(num3)) {&amp;#10;                clicked_image = cue3;&amp;#10;            } else {&amp;#10;                if (mouse_resp_3.isPressedIn(num4)) {&amp;#10;                    clicked_image = cue4;&amp;#10;                } else {&amp;#10;                    if (mouse_resp_3.isPressedIn(num5)) {&amp;#10;                        clicked_image = cue5;&amp;#10;                    } else {&amp;#10;                        if (mouse_resp_3.isPressedIn(num6)) {&amp;#10;                            clicked_image = cue6;&amp;#10;                        } else {&amp;#10;                            if (mouse_resp_3.isPressedIn(num7)) {&amp;#10;                                clicked_image = cue7;&amp;#10;                            } else {&amp;#10;                                if (mouse_resp_3.isPressedIn(num8)) {&amp;#10;                                    clicked_image = cue8;&amp;#10;                                } else {&amp;#10;                                    if (mouse_resp_3.isPressedIn(num9)) {&amp;#10;                                        clicked_image = cue9;&amp;#10;                                    }&amp;#10;                                }&amp;#10;                            }&amp;#10;                        }&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    if ((clicked_image !== null)) {&amp;#10;        click_result = (clicked_image === cor_resp.toString());&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="psychoJS.experiment.addData(&quot;click_result&quot;, click_result);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
